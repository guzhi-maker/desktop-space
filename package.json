{
  "name": "omega-desktop-pet",
  "version": "0.1.0",
  "private": true,
  "description": "Ω desktop pet prototype with Electron, React, and PixiJS.",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "build:electron": "tsc -p tsconfig.node.json && node -e \"require('fs').renameSync('dist-electron/main.js','dist-electron/main.cjs'); require('fs').renameSync('dist-electron/preload.js','dist-electron/preload.cjs')\"",
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.json && npm run build:electron && vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test:e2e": "cross-env NO_PROXY=127.0.0.1,localhost no_proxy=127.0.0.1,localhost playwright test"
  },
  "dependencies": {
    "@greenmansk/react-live2d": "^0.1.1",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.2.4",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
